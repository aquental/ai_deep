# DeepSeek API Key — obtenha em https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-...

# URL base da API (padrão: https://api.deepseek.com)
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Modelo (padrão: deepseek-chat)
# Opções: deepseek-chat, deepseek-reasoner, deepseek-v4-pro
DEEPSEEK_MODEL=deepseek-v4-pro

# reference: https://api-docs.deepseek.com/
